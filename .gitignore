# ============================================
# .gitignore per pipeline di bioinformatica
# Esclude tutti i dati, mantiene solo il codice
# ============================================

# --- Dati biologici grezzi e processati ---
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.fasta
*.fa
*.fna
*.faa
*.ffn
*.frn
*.fasta.gz
*.fa.gz
*.sam
*.bam
*.bai
*.cram
*.crai
*.vcf
*.vcf.gz
*.bcf
*.tbi
*.csi
*.gff
*.gff3
*.gtf
*.bed
*.bedgraph
*.bigwig
*.bw
*.wig
*.pdb
*.mmcif
*.cif
*.mol2
*.sdf
*.xyz
*.h5
*.hdf5
*.mzML
*.mzXML
*.raw
*.ab1
*.scf

# --- Indici e database ---
*.fai
*.dict
*.amb
*.ann
*.bwt
*.pac
*.sa
*.nhr
*.nin
*.nsq
*.phr
*.pin
*.psq
*.idx
*.ht2
*.bt2
*.bt2l

# --- Tabelle e fogli di calcolo ---
*.csv
*.tsv
*.xlsx
*.xls
*.xlsm
*.ods
*.parquet
*.feather

# --- Documenti e presentazioni ---
*.ppt
*.pptx
*.doc
*.docx
*.odt
*.odp
*.pdf
*.rtf

# --- Immagini e grafici ---
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.tif
*.svg
*.eps
*.ps
*.heic
*.webp
*.ico

# --- File compressi e archivi ---
*.zip
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.bz2
*.gz
*.7z
*.rar
*.xz

# --- Cartelle dati comuni ---
data/
Data/
DATA/
raw/
raw_data/
results/
output/
outputs/
work/
tmp/
temp/
intermediate/
processed/
reports/
figures/
plots/
logs/
*.log

# --- Workflow manager (Snakemake / Nextflow) ---
.snakemake/
.nextflow/
.nextflow.log*
work/
trace.txt
timeline.html
report.html
dag.html

# --- Ambienti e cache ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env
.conda/
conda-env/
.ipynb_checkpoints/
.Rhistory
.Rapp.history
.RData
.Ruserdata
.Rproj.user/
renv/library/
renv/local/
renv/staging/

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Segreti e credenziali ---
*.key
*.pem
credentials.json
.env.local
config.local.*

